# -----------------------------------------------------------------------------
# VeloxCourt - Variables de entorno (ejemplo)
# Copiar a `.env` y completar con los valores reales del proyecto de Supabase.
# -----------------------------------------------------------------------------

# Runtime de la app (Vercel / Next): Transaction pooler (puerto 6543).
# En Supabase: Project > Connect > Transaction pooler.
# Soporta más clientes concurrentes que session mode (evita EMAXCONNSESSION).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Migraciones / prisma db push: Session pooler o Direct (puerto 5432).
# Si no está, Prisma usa DATABASE_URL.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# Supabase (cliente) - Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# Opcional: orígenes extra para probar desde celular/túnel (coma-separados)
# ALLOWED_DEV_ORIGINS=source-muscles-now-prompt.trycloudflare.com,192.168.18.62:3000

# WhatsApp Business Cloud API (Meta) — envío automático desde el servidor
# Sin esto, VeloxCourt solo puede "Abrir WhatsApp" (el usuario confirma el envío en el celu).
# Meta for Developers > tu app > WhatsApp > API Setup
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
